# ASR service WebSocket endpoint.
VITE_ASR_WS_URL=ws://192.168.113.44:8001/ws/recognize

# TTS service base URL and speech endpoint.
VITE_TTS_BASE_URL=http://192.168.113.44:8001
VITE_TTS_ENDPOINT=/v1/audio/speech

# Default TTS request parameters used by the digital human.
VITE_TTS_MODEL=matcha-tts
VITE_TTS_VOICE=xiaoxiao
VITE_TTS_RESPONSE_FORMAT=mp3
VITE_TTS_SPEED=1.0

# Dify chat configuration.
# Keep the real API key only in the local .env.developement file.
VITE_DIFY_CHAT_MESSAGES_URL=https://copilot.sino-bridge.com:90/v1/chat-messages
VITE_DIFY_STOP_MESSAGE_URL_TEMPLATE=https://copilot.sino-bridge.com:90/v1/chat-messages/{task_id}/stop
VITE_DIFY_API_KEY=app-your-local-key
VITE_DIFY_USER_PREFIX=digital-human-demo
VITE_DIFY_TIMEOUT_MS=60000

# Video assets for each avatar state.
VITE_VIDEO_IDLE_SRC=/videos/等待1.mp4
VITE_VIDEO_LISTENING_SRC=/videos/思考1.mp4
VITE_VIDEO_THINKING_SRC=/videos/思考1.mp4
VITE_VIDEO_SPEAKING_SRC=/videos/说话2.mp4

# Response timing used by fallback typing and speech completion handling.
VITE_RESPONSE_THINKING_MS=960
VITE_RESPONSE_TYPING_INTERVAL_MS=24
VITE_RESPONSE_SPEAKING_TAIL_MS=420
VITE_RESPONSE_MIN_SPEAKING_MS=1800
VITE_RESPONSE_MS_PER_CHARACTER=105
